# Bluesound Dashboard — copy to .env in repo root
# Full reference: docs/CONFIGURATION.md

# Server
BSD_HOST=127.0.0.1
BSD_PORT=8000
BSD_LOG_LEVEL=INFO
BSD_CORS_ORIGINS=http://localhost:5173
# BSD_STATIC_DIR=../frontend/dist

# Discovery
BSD_DISCOVERY_METHOD=both
BSD_DISCOVERY_TIMEOUT=5
BSD_DISCOVERY_CACHE_TTL=300
BSD_EMPTY_FLEET_REDISCOVERY_SECONDS=30
BSD_DISCOVERED_GRACE_TTL=60
# BSD_SSE_KEEPALIVE_SECONDS=15
# BSD_ALLOW_NON_PRIVATE_IPS=false
# BSD_MDNS_SERVICE=_musc._tcp.local.
# BSD_BLUOS_PORT=11000

# Polling / device HTTP
BSD_POLL_INTERVAL=3
BSD_DEVICE_HTTP_TIMEOUT=3
BSD_MAX_CONCURRENT_DEVICE_CALLS=20
BSD_CONTROL_RATE_LIMIT_SECONDS=0.1
BSD_API_RATE_LIMIT_SECONDS=0.05
# BSD_ENABLE_OPENAPI=true
BSD_CIRCUIT_FAILURE_THRESHOLD=5
BSD_CIRCUIT_SLOW_POLL_SECONDS=15

# XML hardening
# BSD_MAX_XML_SIZE=1048576
# BSD_MAX_XML_DEPTH=20
# BSD_MAX_XML_ELEMENTS=10000
