#!/usr/bin/env bash
# Build production artifacts: frontend dist + ensure backend package is installed.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
VENV="${ROOT}/backend/.venv"
PIP="${VENV}/bin/pip"

log() { printf '[build] %s\n' "$*"; }

if [[ ! -x "${PIP}" ]]; then
  log "missing ${PIP} — run: make install"
  exit 1
fi
if [[ ! -d "${ROOT}/frontend/node_modules" ]]; then
  log "missing frontend/node_modules — run: make install"
  exit 1
fi

log "backend: pip install -e ."
(
  cd "${ROOT}/backend"
  "${PIP}" install -e .
)

log "frontend: npm run build"
(
  cd "${ROOT}/frontend"
  npm run build
)

log "done — UI at frontend/dist (set BSD_STATIC_DIR=frontend/dist for single-process serve)"
