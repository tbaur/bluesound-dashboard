#!/usr/bin/env bash
# Start Bluesound Dashboard for local development in the only safe order:
# API first → wait for healthz → UI. Avoids Vite proxying to a dead :8000.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
API_HOST=127.0.0.1
API_PORT=8000
UI_HOST=127.0.0.1
UI_PORT=8765
HEALTH_URL="http://${API_HOST}:${API_PORT}/api/v1/healthz"
API_PID=""
UI_PID=""

log() { printf '[run] %s\n' "$*"; }

cleanup() {
  local code=$?
  if [[ -n "${UI_PID}" ]] && kill -0 "${UI_PID}" 2>/dev/null; then
    kill "${UI_PID}" 2>/dev/null || true
    wait "${UI_PID}" 2>/dev/null || true
  fi
  if [[ -n "${API_PID}" ]] && kill -0 "${API_PID}" 2>/dev/null; then
    kill "${API_PID}" 2>/dev/null || true
    wait "${API_PID}" 2>/dev/null || true
  fi
  exit "${code}"
}
trap cleanup EXIT INT TERM

free_port() {
  local port="$1"
  local pids
  pids="$(lsof -nP -t -iTCP:"${port}" -sTCP:LISTEN 2>/dev/null || true)"
  if [[ -n "${pids}" ]]; then
    log "freeing :${port} (pids ${pids})"
    # shellcheck disable=SC2086
    kill ${pids} 2>/dev/null || true
    sleep 0.4
    pids="$(lsof -nP -t -iTCP:"${port}" -sTCP:LISTEN 2>/dev/null || true)"
    if [[ -n "${pids}" ]]; then
      # shellcheck disable=SC2086
      kill -9 ${pids} 2>/dev/null || true
      sleep 0.2
    fi
  fi
}

wait_for_health() {
  local attempts=60
  local i
  for ((i = 1; i <= attempts; i++)); do
    if curl -fsS -m 1 "${HEALTH_URL}" >/dev/null 2>&1; then
      log "API healthy at ${HEALTH_URL}"
      return 0
    fi
    if [[ -n "${API_PID}" ]] && ! kill -0 "${API_PID}" 2>/dev/null; then
      log "API process exited before becoming healthy"
      return 1
    fi
    sleep 0.25
  done
  log "timed out waiting for ${HEALTH_URL}"
  return 1
}

UVICORN="${ROOT}/backend/.venv/bin/uvicorn"
if [[ ! -x "${UVICORN}" ]]; then
  log "missing ${UVICORN} — run: cd backend && python3 -m venv .venv && .venv/bin/pip install -e '.[dev]'"
  exit 1
fi
if [[ ! -d "${ROOT}/frontend/node_modules" ]]; then
  log "missing frontend/node_modules — run: cd frontend && npm ci"
  exit 1
fi

free_port "${API_PORT}"
free_port "${UI_PORT}"

log "starting API on ${API_HOST}:${API_PORT}"
(
  cd "${ROOT}/backend"
  exec "${UVICORN}" app.main:app --reload --host "${API_HOST}" --port "${API_PORT}"
) &
API_PID=$!

wait_for_health

log "starting UI on ${UI_HOST}:${UI_PORT}"
(
  cd "${ROOT}/frontend"
  exec npm run dev -- --host "${UI_HOST}" --port "${UI_PORT}" --strictPort
) &
UI_PID=$!

log "ready — open http://${UI_HOST}:${UI_PORT}/"
wait "${API_PID}" "${UI_PID}"
